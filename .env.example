# ─────────────────────────────────────────────
#  RAGHybrid — przykładowa konfiguracja
#  Skopiuj do .env i wypełnij swoimi wartościami
# ─────────────────────────────────────────────

# PostgreSQL
POSTGRES_DB=rag_db
POSTGRES_USER=rag_user
POSTGRES_PASSWORD=changeme
DATABASE_URL=postgresql://rag_user:changeme@raghybrid-db:5432/rag_db

# ─── Backend LLM ──────────────────────────────
#
# BACKEND_TYPE ustawia domyślny format API dla wszystkich komponentów:
#   ollama  — Ollama API (/api/embeddings, /api/generate)   [domyślnie]
#   openai  — OpenAI-compatible API (/v1/embeddings, /v1/chat/completions)
#             Działa z: vLLM, llama.cpp server, LM Studio, OpenAI, Groq itp.
#
# Możesz nadpisać osobno dla każdego komponentu:
#   EMBED_BACKEND_TYPE   — tylko embeddingi
#   GEN_BACKEND_TYPE     — tylko generowanie
#   RERANK_BACKEND_TYPE  — tylko reranker
# Puste = dziedziczy z BACKEND_TYPE.
#
BACKEND_TYPE=ollama
EMBED_BACKEND_TYPE=
GEN_BACKEND_TYPE=
RERANK_BACKEND_TYPE=

# API key dla OpenAI-compatible backendów
# vLLM i llama.cpp akceptują dowolną wartość (np. "na"), OpenAI wymaga prawdziwego klucza
OPENAI_API_KEY=na

# ─── Adresy serwerów LLM ──────────────────────
#
# Możesz mieć jeden serwer lub kilka dla różnych komponentów.
# Przykłady dla różnych backendów:
#
#   Ollama:       http://localhost:11434
#   vLLM:         http://localhost:8080
#   llama.cpp:    http://localhost:8080
#   LM Studio:    http://localhost:1234
#
OLLAMA_EMBED_URL=http://localhost:11434
OLLAMA_EMBED_MODEL=nomic-embed-text

OLLAMA_GPU_URL=http://localhost:11434
OLLAMA_CPU_URL=http://localhost:11434
OLLAMA_LAPTOP_URL=http://localhost:11434

# ─── Reranker ─────────────────────────────────
# ollama_embedding = ranking przez cosine similarity z modelem embeddingowym
#                    działa zarówno z Ollama jak i OpenAI-compatible backendami
# llm              = ranking przez LLM (wolniej, nie wymaga osobnego modelu)
RERANK_BACKEND=ollama_embedding
OLLAMA_RERANK_URL=
OLLAMA_RERANK_MODEL=qllama/bce-reranker-base_v1
RERANK_MAX_CHARS=1600
RERANK_MIN_SCORE_SPREAD=0.02

# ─── Neo4j ────────────────────────────────────
NEO4J_URI=bolt://raghybrid-neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=changeme

# ─── Relevance gate ───────────────────────────
RAG_MIN_RELEVANCE_SCORE=0.45
RAG_MIN_LEXICAL_OVERLAP=0.10
RAG_MIN_RESULTS=1
RAG_REQUIRE_EVIDENCE_FOR_GRAPH=true
RAG_GATE_DEBUG=true

# ─── Telemetria ───────────────────────────────
RAG_RETRIEVAL_TELEMETRY_PATH=/runtime/raghybrid_retrieval_telemetry.jsonl

# ─── OpenWebUI (opcjonalne) ───────────────────
# OPENWEBUI_DB_PATH=/openwebui-data/webui.db
