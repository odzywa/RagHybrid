# ─────────────────────────────────────────────
#  RAGHybrid — przykładowa konfiguracja
#  Skopiuj do .env i wypełnij swoimi wartościami
# ─────────────────────────────────────────────

# PostgreSQL
POSTGRES_DB=rag_db
POSTGRES_USER=rag_user
POSTGRES_PASSWORD=changeme
DATABASE_URL=postgresql://rag_user:changeme@raghybrid-db:5432/rag_db

# ─── Ollama — embeddingi ───────────────────────
# Adres serwera Ollama do generowania embeddingów
OLLAMA_EMBED_URL=http://localhost:11434
OLLAMA_EMBED_MODEL=nomic-embed-text

# ─── Ollama — generowanie odpowiedzi ──────────
# Możesz mieć jeden serwer lub kilka (CPU / GPU / laptop)
OLLAMA_CPU_URL=http://localhost:11434
OLLAMA_GPU_URL=http://localhost:11434
OLLAMA_LAPTOP_URL=http://localhost:11434

# ─── Reranker ─────────────────────────────────
# ollama_embedding = reranker BCE przez Ollama embeddings
# Zostaw puste OLLAMA_RERANK_URL żeby używać OLLAMA_EMBED_URL
RERANK_BACKEND=ollama_embedding
OLLAMA_RERANK_URL=
OLLAMA_RERANK_MODEL=qllama/bce-reranker-base_v1
RERANK_MAX_CHARS=1600
RERANK_MIN_SCORE_SPREAD=0.02

# ─── Neo4j ────────────────────────────────────
NEO4J_URI=bolt://raghybrid-neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=changeme

# ─── Relevance gate ───────────────────────────
# Minimalny fused_score do zaakceptowania wyników RAG
# exp(-d/30): d=15→0.607  d=20→0.513  d=25→0.435
RAG_MIN_RELEVANCE_SCORE=0.45
RAG_MIN_LEXICAL_OVERLAP=0.10
RAG_MIN_RESULTS=1
RAG_REQUIRE_EVIDENCE_FOR_GRAPH=true
RAG_GATE_DEBUG=true

# ─── Telemetria ───────────────────────────────
RAG_RETRIEVAL_TELEMETRY_PATH=/runtime/raghybrid_retrieval_telemetry.jsonl

# ─── OpenWebUI (opcjonalne) ───────────────────
# Ścieżka do bazy OpenWebUI jeśli montujesz ją do kontenera
# OPENWEBUI_DB_PATH=/openwebui-data/webui.db
